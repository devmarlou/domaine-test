{% comment %}
  Section: Featured Products

  Renders a grid (or mobile slider) of product cards from a chosen collection.

  Renders:
  - snippets/product-card.liquid (one per product)

  Schema:
  - Content: heading, collection, products_to_show (4-16)
  - Layout: columns_desktop (2 / 3 / 4), columns_mobile (1 / 2 / slider)
  - Display: show_vendor, show_swatches, show_card_badges
  - Card: image_ratio, card_border_color, card_border_radius,
  badge_background_color, sale_badge_text, sold_out_badge_text

  Implementation notes
  ────────────────────
  Card style overrides emit CSS custom properties on the section root
  (--card-border-color, --card-radius, --badge-bg); the card snippet
  reads them via Tailwind arbitrary values, e.g.
  `border-[color:var(--card-border-color)]`.

  Layout modes (computed):
    use_mobile_slider  ← columns_mobile == 'slider'
    use_desktop_slider ← products_to_show > columns_desktop
                         (auto: more cards than fit in the grid →
                         horizontal scroller on desktop)

  The four permutations are handled by a single template with computed
  container + card-wrapper class strings, instead of four duplicated
  branches.

  Cards-per-row + slider-card-width Tailwind classes are looked up via
  `case` (Tailwind JIT scans source for full class strings — dynamic
  concatenation like `grid-cols-{{ n }}` would not be picked up).

  Slider controls (desktop only) — prev/next chevrons + "X of Y"
  counter sit inline with the heading. Native scroll-snap drives the
  motion; JS only handles button clicks, counter updates (via
  IntersectionObserver on each card), and disabled state at the
  scroll boundaries. See frontend/entrypoints/main.js.
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show
  assign columns_desktop = section.settings.columns_desktop
  assign columns_mobile = section.settings.columns_mobile

  case columns_desktop
    when '2'
      assign desktop_cols_class = 'lg:grid-cols-2'
      assign desktop_slider_card_class = 'lg:w-[calc((100%-1.5rem)/2)]'
      assign columns_desktop_n = 2
    when '3'
      assign desktop_cols_class = 'lg:grid-cols-3'
      assign desktop_slider_card_class = 'lg:w-[calc((100%-3rem)/3)]'
      assign columns_desktop_n = 3
    else
      assign desktop_cols_class = 'lg:grid-cols-4'
      assign desktop_slider_card_class = 'lg:w-[calc((100%-4.5rem)/4)]'
      assign columns_desktop_n = 4
  endcase

  case columns_mobile
    when '2'
      assign mobile_cols_class = 'grid-cols-2'
    else
      assign mobile_cols_class = 'grid-cols-1'
  endcase

  assign use_mobile_slider = false
  if columns_mobile == 'slider'
    assign use_mobile_slider = true
  endif

  assign use_desktop_slider = false
  if products_to_show > columns_desktop_n
    assign use_desktop_slider = true
  endif

  assign products_total = collection.products_count | at_most: products_to_show

  assign show_controls = false
  if use_desktop_slider and products_total > columns_desktop_n
    assign show_controls = true
  endif

  if use_mobile_slider and use_desktop_slider
    assign container_class = 'flex overflow-x-auto no-scrollbar snap-x snap-mandatory gap-4 lg:gap-6 px-1 scroll-px-1'
    assign card_wrapper_class = 'snap-start shrink-0 w-[78%] sm:w-[48%] ' | append: desktop_slider_card_class
  elsif use_mobile_slider
    assign container_class = 'flex overflow-x-auto no-scrollbar snap-x snap-mandatory gap-4 px-1 scroll-px-1 lg:grid lg:overflow-visible lg:gap-6 lg:px-0 lg:scroll-px-0 ' | append: desktop_cols_class
    assign card_wrapper_class = 'snap-start shrink-0 w-[78%] sm:w-[48%] lg:w-auto'
  elsif use_desktop_slider
    assign container_class = 'grid gap-4 lg:flex lg:overflow-x-auto lg:no-scrollbar lg:snap-x lg:snap-mandatory lg:gap-6 lg:px-1 lg:scroll-px-1 ' | append: mobile_cols_class
    assign card_wrapper_class = 'lg:snap-start lg:shrink-0 ' | append: desktop_slider_card_class
  else
    assign container_class = 'grid gap-4 lg:gap-6 ' | append: mobile_cols_class | append: ' ' | append: desktop_cols_class
    assign card_wrapper_class = ''
  endif
-%}

<div class="featured-products full-width grid grid-cols-[var(--content-grid)] pt-12 pb-10 lg:pt-20 lg:pb-16 bg-[color:var(--section-bg,#F7F7F7)]" style="--card-border-color: {{ section.settings.card_border_color }}; --card-radius: {{ section.settings.card_border_radius }}px; --section-bg: {{ section.settings.section_background_color }}; --badge-bg: {{ section.settings.badge_background_color }};" data-featured-products>
  <div class="col-start-2">
    {%- if heading != blank or show_controls -%}
      <div class="flex items-end justify-between gap-4 mb-8 md:mb-12">
        {%- if heading != blank -%}
          <h2 class="text-2xl md:text-3xl font-medium text-[color:var(--color-foreground,#333333)]">
            {{ heading }}
          </h2>
        {%- else -%}
          <div></div>
        {%- endif -%}

        {%- if show_controls -%}
          <div class="hidden lg:flex items-center gap-4 shrink-0" data-slider-controls>
            <span class="text-sm tabular-nums text-[color:var(--color-foreground,#333333)] opacity-70">
              {%- capture current_html -%}<span data-slider-current>{{ columns_desktop_n }}</span>{%- endcapture -%}
              {%- capture total_html -%}<span data-slider-total>{{ products_total }}</span>{%- endcapture -%}
              {{ 'sections.featured_products.slider.counter_html' | t: current: current_html, total: total_html }}
            </span>
            <div class="flex gap-2">
              <button
                type="button"
                data-slider-prev
                aria-label="{{ 'sections.featured_products.slider.previous' | t }}"
                class="flex size-10 items-center justify-center rounded-full border border-[color:var(--card-border-color,#E8E8E8)] text-[color:var(--color-foreground,#333333)] cursor-pointer motion-safe:transition-colors hover:bg-black/5 focus-visible:ring-2 focus-visible:ring-[color:var(--color-foreground,#333333)] focus-visible:outline-none disabled:opacity-30 disabled:cursor-not-allowed"
              >
                <svg class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 0 1 0 1.06L9.06 10l3.73 3.71a.75.75 0 1 1-1.06 1.06l-4.24-4.24a.75.75 0 0 1 0-1.06l4.24-4.24a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
                </svg>
              </button>
              <button
                type="button"
                data-slider-next
                aria-label="{{ 'sections.featured_products.slider.next' | t }}"
                class="flex size-10 items-center justify-center rounded-full border border-[color:var(--card-border-color,#E8E8E8)] text-[color:var(--color-foreground,#333333)] cursor-pointer motion-safe:transition-colors hover:bg-black/5 focus-visible:ring-2 focus-visible:ring-[color:var(--color-foreground,#333333)] focus-visible:outline-none disabled:opacity-30 disabled:cursor-not-allowed"
              >
                <svg class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 0-1.06L10.94 10 7.21 6.29a.75.75 0 1 1 1.06-1.06l4.24 4.24a.75.75 0 0 1 0 1.06l-4.24 4.24a.75.75 0 0 1-1.06 0Z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection == blank or collection.products_count == 0 -%}
      <p class="text-[color:var(--color-foreground,#333333)] opacity-60">
        {{ 'sections.featured_products.empty_state' | t }}
      </p>
    {%- else -%}
      <div class="{{ container_class }}"{% if show_controls %} data-slider-track{% endif %}>
        {%- for product in collection.products limit: products_to_show -%}
          <div class="{{ card_wrapper_class }}">
            {%- render 'product-card'
              , product: product
              , show_vendor: section.settings.show_vendor
              , show_swatches: section.settings.show_swatches
              , show_badges: section.settings.show_card_badges
              , image_ratio: section.settings.image_ratio
              , sale_badge_text: section.settings.sale_badge_text
              , sold_out_badge_text: section.settings.sold_out_badge_text
            -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
  {
    "name": "t:sections.featured_products.name",
    "tag": "section",
    "class": "section-featured-products",
    "settings": [
      {
        "type": "header",
        "content": "t:sections.featured_products.headers.content"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "t:sections.featured_products.settings.heading.label",
        "default": "Featured products"
      },
      {
        "type": "collection",
        "id": "collection",
        "label": "t:sections.featured_products.settings.collection.label"
      },
      {
        "type": "range",
        "id": "products_to_show",
        "label": "t:sections.featured_products.settings.products_to_show.label",
        "info": "t:sections.featured_products.settings.products_to_show.info",
        "min": 4,
        "max": 16,
        "step": 1,
        "default": 4
      }, {
        "type": "header",
        "content": "t:sections.featured_products.headers.layout"
      }, {
        "type": "select",
        "id": "columns_desktop",
        "label": "t:sections.featured_products.settings.columns_desktop.label",
        "options": [
          {
            "value": "2",
            "label": "2"
          },
          {
            "value": "3",
            "label": "3"
          },
          {
            "value": "4",
            "label": "4"
          }
        ],
        "default": "4"
      }, {
        "type": "select",
        "id": "columns_mobile",
        "label": "t:sections.featured_products.settings.columns_mobile.label",
        "options": [
          {
            "value": "1",
            "label": "t:sections.featured_products.settings.columns_mobile.options.1"
          }, {
            "value": "2",
            "label": "t:sections.featured_products.settings.columns_mobile.options.2"
          }, {
            "value": "slider",
            "label": "t:sections.featured_products.settings.columns_mobile.options.slider"
          }
        ],
        "default": "1"
      }, {
        "type": "header",
        "content": "t:sections.featured_products.headers.display"
      }, {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "t:sections.featured_products.settings.show_vendor.label",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_swatches",
        "label": "t:sections.featured_products.settings.show_swatches.label",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_card_badges",
        "label": "t:sections.featured_products.settings.show_card_badges.label",
        "info": "t:sections.featured_products.settings.show_card_badges.info",
        "default": true
      }, {
        "type": "header",
        "content": "t:sections.featured_products.headers.section_style"
      }, {
        "type": "color",
        "id": "section_background_color",
        "label": "t:sections.featured_products.settings.section_background_color.label",
        "default": "#F7F7F7"
      }, {
        "type": "header",
        "content": "t:sections.featured_products.headers.card_style"
      }, {
        "type": "select",
        "id": "image_ratio",
        "label": "t:sections.featured_products.settings.image_ratio.label",
        "options": [
          {
            "value": "square",
            "label": "t:sections.featured_products.settings.image_ratio.options.square"
          }, {
            "value": "portrait",
            "label": "t:sections.featured_products.settings.image_ratio.options.portrait"
          }, {
            "value": "natural",
            "label": "t:sections.featured_products.settings.image_ratio.options.natural"
          }
        ],
        "default": "square"
      }, {
        "type": "color",
        "id": "card_border_color",
        "label": "t:sections.featured_products.settings.card_border_color.label",
        "default": "#E8E8E8"
      }, {
        "type": "range",
        "id": "card_border_radius",
        "label": "t:sections.featured_products.settings.card_border_radius.label",
        "min": 0,
        "max": 24,
        "step": 1,
        "unit": "px",
        "default": 10
      }, {
        "type": "color",
        "id": "badge_background_color",
        "label": "t:sections.featured_products.settings.badge_background_color.label",
        "default": "#FFFFFF"
      }, {
        "type": "text",
        "id": "sale_badge_text",
        "label": "t:sections.featured_products.settings.sale_badge_text.label",
        "info": "t:sections.featured_products.settings.sale_badge_text.info"
      }, {
        "type": "text",
        "id": "sold_out_badge_text",
        "label": "t:sections.featured_products.settings.sold_out_badge_text.label",
        "info": "t:sections.featured_products.settings.sold_out_badge_text.info"
      }
    ],
    "presets": [
      {
        "name": "t:sections.featured_products.name",
        "category": "t:sections.featured_products.category"
      }
    ],
    "disabled_on": {
      "groups": ["header", "footer"]
    }
  }
{% endschema %}